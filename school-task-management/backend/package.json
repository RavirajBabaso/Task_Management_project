    "@types/multer": "^1.4.12",
    "@types/node": "^22.5.1",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.15",
    "@types/pdfkit": "^0.13.5",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
